# ============================================================
# VS Code (Visual Studio Code) - macOS
# ============================================================

# VS Code workspace settings (local)
.vscode/*.json
!vscode/settings.json

# VS Code internal files
.vscode-diff
.vscodeignore

# Editor state and cache
.vscode/*/cache
.vscode/*/History
.vscode/*/storage

# Lock files
.vscode/*/lock
.vscode/*/node-lock.json


# ============================================================
# macOS System Files
# ============================================================

# AppleDouble files
*.DS_Store
*.AppleDouble
*.LSOverride

# Icon files
_Icon

# Thumb cache
.thumbnail
.thumbs

# Trash
.Trash-*

# Spotlight
.Spotlight-V100
.Spotlight-V20

# Network files
*.density

# ============================================================
# General Development Files
# ============================================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE general
.idea/
*.swp
*.swo
*~

# Shell scripts temp
*.sh-bak

# Git itself
.git/